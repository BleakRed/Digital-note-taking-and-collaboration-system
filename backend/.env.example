# Backend Configuration
# =====================

# Database connection string (PostgreSQL)
# For local dev with Docker: postgresql://notion_user:notion_pass@localhost:5433/notion_clone?schema=public
# For local dev without Docker: postgresql://postgres:postgres@localhost:5432/notion_clone?schema=public
DATABASE_URL="postgresql://notion_user:notion_pass@localhost:5433/notion_clone?schema=public"

# Direct URL for Prisma migrations (required when using connection poolers like pgBouncer)
DIRECT_URL="postgresql://notion_user:notion_pass@localhost:5433/notion_clone?schema=public"

# Secret for JWT signing
JWT_SECRET="your_very_secure_random_secret_here"

# Port to run the server on
PORT=8000

# Backend URL for generating file upload URLs (auto-detected from request if not set)
BACKEND_URL="http://localhost:8000"

# Frontend URL for CORS and email verification links
FRONTEND_URL="http://localhost:3000"

# SMTP Configuration (optional — leave empty to skip email in dev)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Notion Clone <noreply@example.com>"

# Supabase Configuration (optional — leave empty to use local storage)
# Sign up at https://supabase.com/ for a free account
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="notion-clone-files"
